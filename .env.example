# =============================================================================
# RCA Agent — Plantilla de configuración
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este fichero y renómbralo ".env"  (sin el ".example")
#   2. Rellena los valores que necesitas
#   3. El fichero ".env" NUNCA debe subirse a git (ya está en .gitignore)
# =============================================================================


# -----------------------------------------------------------------------------
# OBLIGATORIO
# -----------------------------------------------------------------------------

# Proveedor de LLM que usará el agente para razonar: "gemini" (por defecto)
# o "anthropic". Solo hace falta rellenar la API key del proveedor elegido.
LLM_PROVIDER=gemini

# Clave de API de Google (Gemini). Obligatoria si LLM_PROVIDER=gemini.
# Puedes obtenerla en: https://aistudio.google.com/apikey
GEMINI_API_KEY=aqui-va-tu-clave-de-gemini

# Clave de API de Anthropic. Obligatoria SOLO si LLM_PROVIDER=anthropic.
# Puedes obtenerla (o crearla) en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-aqui-va-tu-clave


# -----------------------------------------------------------------------------
# OPCIONALES (tienen valor por defecto si se dejan en blanco)
# -----------------------------------------------------------------------------

# Modelo de Gemini a usar (solo si LLM_PROVIDER=gemini).
# Por defecto: gemini-2.5-pro
GEMINI_MODEL=

# Modelo de Claude a usar (solo si LLM_PROVIDER=anthropic).
# Por defecto: claude-opus-4-8
ANTHROPIC_MODEL=

# Puerto en el que escuchará el servidor webhook.
# PI System debe apuntar sus notificaciones a: http://ESTE_SERVIDOR:<WEBHOOK_PORT>/notification
# Por defecto: 8080
WEBHOOK_PORT=8090

# Token secreto para verificar que las notificaciones realmente vienen de PI System.
# Si lo configuras aquí, PI debe enviar este mismo valor en la cabecera HTTP "X-PI-Secret".
# Si lo dejas vacío, el servidor acepta notificaciones de cualquier origen (menos seguro).
# Recomendado: usa una cadena larga y aleatoria, por ejemplo: openssl rand -hex 32
WEBHOOK_SECRET=

# Zona horaria del servidor para mostrar los timestamps en el log.
# Valores válidos: nombres de zona IANA, p.ej. Europe/Madrid, America/New_York
# Por defecto: Europe/Madrid
PI_LOCAL_TIMEZONE=Europe/Madrid
